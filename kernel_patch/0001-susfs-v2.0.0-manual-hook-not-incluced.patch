+		strncpy(my_uname.version, info.version, __NEW_UTS_LEN);
+	}
+	is_susfs_uname_set = true;
+	write_sequnlock(&susfs_uname_seqlock);
+	SUSFS_LOGI("set spoofed release: '%s', version: '%s'\n",
+				my_uname.release, my_uname.version);
+
+	info.err = 0;
